<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Require Vulkan 1.0 support -->
    <uses-feature
        android:name="android.hardware.vulkan.version"
        android:version="0x400000"
        android:required="true" />

    <!-- Require OpenGL ES 3.0 as fallback indicator -->
    <uses-feature
        android:name="android.hardware.opengles.aep"
        android:required="false" />

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:hasCode="false"
        android:extractNativeLibs="true">

        <!-- NativeActivity for pure C++ application -->
        <activity
            android:name="android.app.NativeActivity"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|smallestScreenSize"
            android:screenOrientation="landscape"
            android:exported="true">

            <!-- Specify the native library to load -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="msplat_android" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
