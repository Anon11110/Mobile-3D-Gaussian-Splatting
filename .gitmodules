[submodule "rhi/third-party/Vulkan-Headers"]
	path = rhi/third-party/Vulkan-Headers
	url = https://github.com/KhronosGroup/Vulkan-Headers.git
[submodule "third-party/glfw"]
	path = third-party/glfw
	url = https://github.com/glfw/glfw.git
[submodule "third-party/imgui"]
	path = third-party/imgui
	url = https://github.com/ocornut/imgui.git
[submodule "rhi/third-party/VMA"]
	path = rhi/third-party/VMA
	url = https://github.com/GPUOpen-LibrariesAndSDKs/VulkanMemoryAllocator.git
[submodule "third-party/glm"]
	path = third-party/glm
	url = https://github.com/g-truc/glm.git
[submodule "third-party/rpmalloc"]
	path = third-party/rpmalloc
	url = https://github.com/mjansson/rpmalloc.git
[submodule "third-party/rapidhash"]
	path = third-party/rapidhash
	url = https://github.com/Nicoshev/rapidhash.git
[submodule "third-party/spdlog"]
	path = third-party/spdlog
	url = https://github.com/gabime/spdlog.git
